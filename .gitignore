# Python build artifacts
__pycache__/
*.pyc

# Generated tool output (regenerated by validate.py / graph_integrity.py / index.py)
tools/output/

# Local / machine-specific Claude Code config (not for shared repo)
.claude/settings.local.json

# Obsidian per-machine UI state
.obsidian/workspace.json

# Obsidian community-plugin binaries + per-machine plugin state (RRI, not architecture).
# Reinstallable from .obsidian/community-plugins.json; keeps ~11 MB of third-party
# code and a plugin secret (local-rest-api key) out of the shared public repo.
.obsidian/plugins/

# Stray local scratch
/tree.txt
